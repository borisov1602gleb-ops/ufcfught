# Скопируйте в backend/.env и задайте значения для своего окружения.

# Секрет для подписи JWT. В проде — длинная случайная строка.
APP_SECRET_KEY=change-me-to-a-long-random-string

# Время жизни токена доступа (минуты).
APP_ACCESS_TOKEN_EXPIRE_MINUTES=480

# Разрешённые источники для CORS (адреса фронтенда), через запятую в JSON-формате.
# APP_CORS_ORIGINS=["http://localhost:5173"]
