<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>URBAN CUP 2025 | Открытый футбольный турнир</title>
    <!-- Подключение шрифтов -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    
    <style>
        /* ==========================================================================
           CSS ПЕРЕМЕННЫЕ И БАЗОВЫЕ НАСТРОЙКИ
           ========================================================================== */
        :root {
            --color-bg: #0d0d0d;
            --color-bg-alt: #161616;
            --color-card: #1e1e1e;
            --color-card-hover: #262626;
            --color-primary: #21a038;
            --color-primary-hover: #2ad049;
            --color-text: #ffffff;
            --color-text-muted: #999999;
            --color-border: #333333;
            --color-gold: #ffd700;
            --color-silver: #c0c0c0;
            --color-bronze: #cd7f32;
            --color-danger: #e74c3c;
            --font-main: 'Inter', sans-serif;
            --transition-speed: 0.3s;
            --border-radius: 12px;
            --header-height: 70px;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: var(--font-main);
            background-color: var(--color-bg);
            color: var(--color-text);
            line-height: 1.6;
            overflow-x: hidden;
        }

        a {
            color: inherit;
            text-decoration: none;
        }

        button {
            cursor: pointer;
            font-family: var(--font-main);
            border: none;
            outline: none;
        }

        input, select, textarea {
            font-family: var(--font-main);
        }

        /* Утилиты */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .section-title {
            font-size: 2rem;
            font-weight: 800;
            text-transform: uppercase;
            margin-bottom: 2rem;
            position: relative;
            display: inline-block;
        }

        .section-title::after {
            content: '';
            position: absolute;
            left: 0;
            bottom: -5px;
            width: 50%;
            height: 4px;
            background-color: var(--color-primary);
            border-radius: 2px;
        }

        .text-center { text-align: center; }
        .text-primary { color: var(--color-primary); }
        .hidden { display: none !important; }
        .flex { display: flex; }
        .items-center { align-items: center; }
        .justify-between { justify-content: space-between; }
        .mt-4 { margin-top: 1rem; }
        .mb-4 { margin-bottom: 1rem; }

        /* ==========================================================================
           НАВИГАЦИЯ (HEADER)
           ========================================================================== */
        header {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: var(--header-height);
            background-color: rgba(13, 13, 13, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--color-border);
            z-index: 1000;
            display: flex;
            align-items: center;
        }

        .nav-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            width: 100%;
        }

        .logo {
            font-size: 1.5rem;
            font-weight: 900;
            color: var(--color-text);
            display: flex;
            align-items: center;
            gap: 10px;
            user-select: none;
        }

        .logo span {
            color: var(--color-primary);
        }

        .nav-menu {
            display: flex;
            gap: 20px;
            list-style: none;
        }

        .nav-menu li a {
            font-size: 0.95rem;
            font-weight: 500;
            color: var(--color-text-muted);
            transition: color var(--transition-speed);
            padding: 10px 5px;
            position: relative;
        }

        .nav-menu li a:hover,
        .nav-menu li a.active {
            color: var(--color-primary);
        }

        .nav-menu li a.active::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 100%;
            height: 2px;
            background-color: var(--color-primary);
        }

        .burger-btn {
            display: none;
            background: transparent;
            color: var(--color-text);
            font-size: 1.5rem;
            border: none;
        }

        @media (max-width: 900px) {
            .nav-menu {
                position: fixed;
                top: var(--header-height);
                right: -100%;
                width: 250px;
                height: calc(100vh - var(--header-height));
                background-color: var(--color-bg-alt);
                flex-direction: column;
                padding: 30px 20px;
                transition: right var(--transition-speed);
                border-left: 1px solid var(--color-border);
            }
            .nav-menu.open {
                right: 0;
            }
            .burger-btn {
                display: block;
            }
        }

        main {
            padding-top: calc(var(--header-height) + 20px);
            min-height: calc(100vh - 100px);
        }

        /* ==========================================================================
           ГЛАВНАЯ СТРАНИЦА (HOME)
           ========================================================================== */
        /* Hero Секция */
        .hero {
            position: relative;
            height: 70vh;
            min-height: 500px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            margin-top: calc(-1 * var(--header-height) - 20px);
            padding-top: var(--header-height);
            /* Текстура футбольного поля через градиент */
            background: linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.8)), 
                        repeating-linear-gradient(
                            0deg,
                            #1a2e1a,
                            #1a2e1a 40px,
                            #1f381f 40px,
                            #1f381f 80px
                        );
            border-bottom: 3px solid var(--color-primary);
        }

        .hero h1 {
            font-size: 4.5rem;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 10px;
            text-shadow: 0 4px 20px rgba(0,0,0,0.8);
            animation: fadeInDown 1s ease-out;
        }

        .hero p {
            font-size: 1.5rem;
            color: var(--color-text-muted);
            margin-bottom: 30px;
            animation: fadeInUp 1s ease-out;
        }

        .btn-primary {
            background-color: var(--color-primary);
            color: var(--color-text);
            padding: 15px 30px;
            font-size: 1.1rem;
            font-weight: 700;
            border-radius: 30px;
            text-transform: uppercase;
            transition: all var(--transition-speed);
            box-shadow: 0 4px 15px rgba(33, 160, 56, 0.4);
            display: inline-block;
        }

        .btn-primary:hover {
            background-color: var(--color-primary-hover);
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(33, 160, 56, 0.6);
        }

        /* Статистика */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-top: -40px;
            position: relative;
            z-index: 10;
        }

        .stat-card {
            background-color: var(--color-card);
            border: 1px solid var(--color-border);
            border-radius: var(--border-radius);
            padding: 25px 20px;
            text-align: center;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            transition: transform var(--transition-speed);
        }

        .stat-card:hover {
            transform: translateY(-5px);
            border-color: var(--color-primary);
        }

        .stat-value {
            font-size: 2.5rem;
            font-weight: 800;
            color: var(--color-primary);
            line-height: 1;
            margin-bottom: 5px;
        }

        .stat-label {
            font-size: 0.9rem;
            color: var(--color-text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        @media (max-width: 768px) {
            .hero h1 { font-size: 3rem; }
            .hero p { font-size: 1.1rem; }
            .stats-grid { grid-template-columns: repeat(2, 1fr); }
        }

        /* Блоки главной страницы */
        .home-blocks {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 40px;
            margin-top: 60px;
            margin-bottom: 60px;
        }

        @media (max-width: 900px) {
            .home-blocks { grid-template-columns: 1fr; }
        }

        /* Карточки матчей */
        .match-list {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .match-card {
            background-color: var(--color-card);
            border: 1px solid var(--color-border);
            border-radius: var(--border-radius);
            padding: 20px;
            display: flex;
            flex-direction: column;
            transition: background var(--transition-speed);
        }

        .match-card:hover {
            background-color: var(--color-card-hover);
        }

        .match-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
            font-size: 0.85rem;
            color: var(--color-text-muted);
        }

        .match-status.live {
            color: var(--color-primary);
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .pulse {
            width: 8px;
            height: 8px;
            background-color: var(--color-primary);
            border-radius: 50%;
            animation: pulse 1.5s infinite;
        }

        .match-teams {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 1.2rem;
            font-weight: 700;
        }

        .team-name {
            flex: 1;
            text-align: center;
        }

        .team-name.winner {
            color: var(--color-primary);
        }

        .match-score {
            flex: 0 0 80px;
            text-align: center;
            font-size: 1.8rem;
            background: var(--color-bg-alt);
            padding: 5px 10px;
            border-radius: 8px;
            border: 1px solid var(--color-border);
        }

        .match-score.vs {
            font-size: 1.2rem;
            color: var(--color-text-muted);
            border: none;
            background: transparent;
        }

        /* Лидеры (Справа) */
        .leaders-block {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .leader-card {
            background-color: var(--color-card);
            border-radius: var(--border-radius);
            padding: 15px;
            display: flex;
            align-items: center;
            gap: 15px;
            border-left: 4px solid var(--color-primary);
        }

        .leader-icon {
            width: 50px;
            height: 50px;
            background-color: rgba(33, 160, 56, 0.1);
            color: var(--color-primary);
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 1.5rem;
            font-weight: bold;
        }

        .leader-info h4 {
            font-size: 0.9rem;
            color: var(--color-text-muted);
            margin-bottom: 3px;
        }

        .leader-info .name {
            font-size: 1.1rem;
            font-weight: 700;
        }

        .leader-info .stat {
            font-size: 0.9rem;
            color: var(--color-primary);
            font-weight: 600;
        }

        /* Новости */
        .news-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
            margin-bottom: 60px;
        }

        .news-card {
            background-color: var(--color-card);
            border-radius: var(--border-radius);
            padding: 20px;
            border: 1px solid var(--color-border);
        }

        .news-date {
            font-size: 0.8rem;
            color: var(--color-primary);
            margin-bottom: 10px;
            font-weight: 600;
        }

        .news-title {
            font-size: 1.2rem;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .news-excerpt {
            color: var(--color-text-muted);
            font-size: 0.95rem;
            margin-bottom: 15px;
        }

        .news-full {
            display: none;
            color: var(--color-text);
            font-size: 0.95rem;
            margin-top: 15px;
            padding-top: 15px;
            border-top: 1px solid var(--color-border);
        }

        .news-full.show { display: block; }

        .btn-link {
            color: var(--color-primary);
            background: transparent;
            font-size: 0.9rem;
            font-weight: 600;
            text-transform: uppercase;
        }
        .btn-link:hover { text-decoration: underline; }

        /* ==========================================================================
           ТАБЛИЦЫ (ГРУППЫ, БОМБАРДИРЫ)
           ========================================================================== */
        .tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .tab-btn {
            padding: 10px 25px;
            background-color: var(--color-card);
            color: var(--color-text);
            border: 1px solid var(--color-border);
            border-radius: 20px;
            font-weight: 600;
            transition: all var(--transition-speed);
        }

        .tab-btn:hover, .tab-btn.active {
            background-color: var(--color-primary);
            border-color: var(--color-primary);
            color: #fff;
        }

        .table-responsive {
            overflow-x: auto;
            margin-bottom: 30px;
            background-color: var(--color-card);
            border-radius: var(--border-radius);
            border: 1px solid var(--color-border);
        }

        table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }

        th, td {
            padding: 15px;
            border-bottom: 1px solid var(--color-border);
        }

        th {
            font-size: 0.85rem;
            text-transform: uppercase;
            color: var(--color-text-muted);
            font-weight: 600;
            background-color: rgba(0,0,0,0.2);
            white-space: nowrap;
        }

        td { font-size: 0.95rem; font-weight: 500; }

        tr:last-child td { border-bottom: none; }

        tr:hover td { background-color: var(--color-card-hover); }

        /* Подсветка в группах */
        .group-table tr.qualify td {
            border-left: 4px solid var(--color-primary);
        }
        .group-table tr.qualify td:first-child { background: rgba(33, 160, 56, 0.05); }
        .group-table tr.out td { color: var(--color-text-muted); }

        /* Подсветка призеров */
        .stats-table tr.rank-1 td { border-left: 4px solid var(--color-gold); }
        .stats-table tr.rank-2 td { border-left: 4px solid var(--color-silver); }
        .stats-table tr.rank-3 td { border-left: 4px solid var(--color-bronze); }

        .search-bar {
            width: 100%;
            max-width: 400px;
            padding: 12px 20px;
            background-color: var(--color-card);
            border: 1px solid var(--color-border);
            border-radius: 20px;
            color: var(--color-text);
            margin-bottom: 20px;
            outline: none;
        }
        .search-bar:focus { border-color: var(--color-primary); }

        /* ==========================================================================
           СЕТКА ПЛЕЙ-ОФФ (BRACKET)
           ========================================================================== */
        .bracket-container {
            overflow-x: auto;
            padding: 20px 0;
        }

        .bracket {
            display: flex;
            min-width: 800px;
            justify-content: space-between;
        }

        .bracket-round {
            display: flex;
            flex-direction: column;
            justify-content: space-around;
            width: 23%;
            position: relative;
        }

        .bracket-title {
            text-align: center;
            font-weight: 700;
            color: var(--color-primary);
            margin-bottom: 20px;
            text-transform: uppercase;
        }

        .bracket-match {
            background-color: var(--color-card);
            border: 1px solid var(--color-border);
            border-radius: 8px;
            margin: 10px 0;
            position: relative;
            z-index: 2;
            box-shadow: 0 4px 10px rgba(0,0,0,0.3);
        }

        .bracket-team {
            display: flex;
            justify-content: space-between;
            padding: 10px 15px;
            font-size: 0.9rem;
            font-weight: 600;
            border-bottom: 1px solid var(--color-border);
        }
        .bracket-team:last-child { border-bottom: none; }
        
        .bracket-team.winner {
            color: var(--color-primary);
            background-color: rgba(33, 160, 56, 0.05);
        }
        
        .bracket-score { font-weight: 800; }

        /* Линии коннекторы (очень базовая CSS имитация) */
        .bracket-round:not(:last-child)::after {
            content: '';
            position: absolute;
            top: 0; right: -15%;
            width: 15%; height: 100%;
            /* Заглушка для сложных линий */
        }

        .third-place {
            margin-top: 40px;
            width: 23%;
            align-self: flex-end;
        }
        .third-place .bracket-title { color: var(--color-bronze); }

        /* ==========================================================================
           КАРТОЧКИ КОМАНД И МОДАЛКИ
           ========================================================================== */
        .teams-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 20px;
        }

        .team-card {
            background-color: var(--color-card);
            border: 1px solid var(--color-border);
            border-radius: var(--border-radius);
            padding: 20px;
            text-align: center;
            cursor: pointer;
            transition: all var(--transition-speed);
        }
        .team-card:hover {
            border-color: var(--color-primary);
            transform: translateY(-5px);
        }

        .team-color {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            margin: 0 auto 15px;
            border: 3px solid var(--color-bg);
            box-shadow: 0 0 0 2px var(--color-border);
        }

        .team-card h3 { font-size: 1.2rem; margin-bottom: 5px; }
        .team-card p { font-size: 0.85rem; color: var(--color-text-muted); }

        /* Модальные окна */
        .modal-overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.8);
            backdrop-filter: blur(5px);
            z-index: 2000;
            display: flex;
            justify-content: center;
            align-items: center;
            opacity: 0;
            visibility: hidden;
            transition: all var(--transition-speed);
        }
        .modal-overlay.open {
            opacity: 1;
            visibility: visible;
        }

        .modal-content {
            background-color: var(--color-bg-alt);
            width: 90%;
            max-width: 600px;
            max-height: 90vh;
            border-radius: var(--border-radius);
            border: 1px solid var(--color-border);
            padding: 30px;
            overflow-y: auto;
            position: relative;
            transform: scale(0.9);
            transition: transform var(--transition-speed);
        }
        .modal-overlay.open .modal-content { transform: scale(1); }

        .modal-close {
            position: absolute;
            top: 20px; right: 20px;
            background: transparent;
            color: var(--color-text-muted);
            font-size: 1.5rem;
            transition: color var(--transition-speed);
        }
        .modal-close:hover { color: var(--color-danger); }

        /* ==========================================================================
           АДМИН ПАНЕЛЬ
           ========================================================================== */
        .admin-panel { padding: 20px 0; }
        .form-group { margin-bottom: 15px; }
        .form-group label { display: block; margin-bottom: 5px; font-size: 0.9rem; color: var(--color-text-muted); }
        .form-group input, .form-group textarea, .form-group select {
            width: 100%;
            padding: 10px 15px;
            background-color: var(--color-bg);
            border: 1px solid var(--color-border);
            border-radius: 8px;
            color: var(--color-text);
        }
        .form-group input:focus, .form-group textarea:focus { border-color: var(--color-primary); }
        
        .admin-row {
            display: grid;
            grid-template-columns: 1fr 60px 20px 60px 1fr auto;
            gap: 10px;
            align-items: center;
            background: var(--color-card);
            padding: 10px;
            margin-bottom: 10px;
            border-radius: 8px;
            border: 1px solid var(--color-border);
        }
        .admin-row input { text-align: center; padding: 5px; }
        
        .btn-sm { padding: 5px 10px; font-size: 0.8rem; background: var(--color-primary); color: white; border-radius: 5px; }
        .btn-danger { background: var(--color-danger); }
        
        .admin-actions { margin-top: 30px; display: flex; gap: 10px; }

        /* ==========================================================================
           ФУТЕР
           ========================================================================== */
        footer {
            background-color: var(--color-bg-alt);
            border-top: 1px solid var(--color-border);
            padding: 40px 0 20px;
            margin-top: 60px;
        }

        .footer-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 30px;
            margin-bottom: 30px;
        }

        .footer-logo { font-size: 1.5rem; font-weight: 900; margin-bottom: 15px; }
        .footer-logo span { color: var(--color-primary); }
        
        .footer-links { list-style: none; }
        .footer-links li { margin-bottom: 10px; }
        .footer-links a { color: var(--color-text-muted); transition: color 0.3s; }
        .footer-links a:hover { color: var(--color-primary); }

        .social-icons { display: flex; gap: 15px; margin-top: 15px; }
        .social-icons a {
            display: flex; justify-content: center; align-items: center;
            width: 40px; height: 40px;
            background: var(--color-card); border-radius: 50%;
            transition: all 0.3s;
        }
        .social-icons a:hover { background: var(--color-primary); transform: translateY(-3px); }

        .copyright {
            text-align: center;
            color: var(--color-text-muted);
            font-size: 0.85rem;
            padding-top: 20px;
            border-top: 1px solid var(--color-border);
        }

        /* Анимации */
        @keyframes fadeInDown {
            from { opacity: 0; transform: translateY(-20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @keyframes pulse {
            0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(33, 160, 56, 0.7); }
            70% { transform: scale(1); box-shadow: 0 0 0 6px rgba(33, 160, 56, 0); }
            100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(33, 160, 56, 0); }
        }
        .fade-in { animation: fadeInUp 0.5s ease-out; }
    </style>
</head>
<body>

    <!-- НАВИГАЦИЯ -->
    <header>
        <div class="container nav-container">
            <div class="logo" id="logo-trigger" style="cursor: pointer;">
                URBAN<span>CUP</span>
            </div>
            <ul class="nav-menu" id="nav-menu">
                <li><a href="#home" class="nav-link active">Главная</a></li>
