            ]
        };

        // Загрузка данных из localStorage или использование дефолтных
        let appData = JSON.parse(localStorage.getItem('urbanCupData')) || JSON.parse(JSON.stringify(mockData));

        function saveData() {
            localStorage.setItem('urbanCupData', JSON.stringify(appData));
            renderAll();
        }

        /* ==========================================================================
           РОУТИНГ И НАВИГАЦИЯ
           ========================================================================== */
        function navigate(hash) {
            const validHashes = ['#home', '#groups', '#playoff', '#stats', '#schedule', '#teams', '#admin'];
            const target = validHashes.includes(hash) ? hash : '#home';
            
            // Скрытие всех секций
            document.querySelectorAll('.view-section').forEach(sec => sec.classList.add('hidden'));
            
            // Отображение целевой
            document.querySelector(target).classList.remove('hidden');
            document.querySelector(target).classList.add('fade-in');
            
            // Обновление активной ссылки
            document.querySelectorAll('.nav-link').forEach(link => {
                link.classList.remove('active');
                if(link.getAttribute('href') === target) link.classList.add('active');
            });

            // Закрытие моб. меню
            document.getElementById('nav-menu').classList.remove('open');
            
            // Специфичные рендеры для секций
            if(target === '#stats') renderStats('scorers');
            
            window.scrollTo(0,0);
        }

        window.addEventListener('hashchange', () => navigate(window.location.hash));

        // Бургер меню
        document.getElementById('burger-btn').addEventListener('click', () => {
            document.getElementById('nav-menu').classList.toggle('open');
        });

        // Скрытый вход в админку по двойному клику на логотип
        document.getElementById('logo-trigger').addEventListener('dblclick', () => {
            document.getElementById('login-modal').classList.add('open');
        });

        /* ==========================================================================
           ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ
           ========================================================================== */
        function getTeam(id) {
            return appData.teams.find(t => t.id === id) || { name: "TBD", color: "#333" };
        }

        function calculateTeamStats() {
            let stats = {};
            appData.teams.forEach(t => {
                stats[t.id] = { id: t.id, name: t.name, color: t.color, group: t.group, P: 0, W: 0, D: 0, L: 0, GF: 0, GA: 0, GD: 0, Pts: 0 };
            });

            appData.matches.filter(m => m.status === 'finished').forEach(m => {
                if(!stats[m.teamA] || !stats[m.teamB]) return;
                
                stats[m.teamA].P++; stats[m.teamB].P++;
                stats[m.teamA].GF += m.scoreA; stats[m.teamB].GF += m.scoreB;
                stats[m.teamA].GA += m.scoreB; stats[m.teamB].GA += m.scoreA;
                
                if(m.scoreA > m.scoreB) { stats[m.teamA].W++; stats[m.teamB].L++; stats[m.teamA].Pts += 3; }
                else if(m.scoreA < m.scoreB) { stats[m.teamB].W++; stats[m.teamA].L++; stats[m.teamB].Pts += 3; }
                else { stats[m.teamA].D++; stats[m.teamB].D++; stats[m.teamA].Pts += 1; stats[m.teamB].Pts += 1; }
            });

            Object.values(stats).forEach(s => s.GD = s.GF - s.GA);
            return stats;
        }

        function generateMatchHTML(m, includeDate = true) {
            const tA = getTeam(m.teamA);
            const tB = getTeam(m.teamB);
            let statusHTML = '';
            if(m.status === 'live') statusHTML = `<span class="match-status live"><div class="pulse"></div> LIVE</span>`;
            else if(m.status === 'finished') statusHTML = `<span class="match-status">Завершён</span>`;
            else statusHTML = `<span class="match-status">Предстоит</span>`;

            let scoreHTML = m.status === 'finished' ? `<div class="match-score">${m.scoreA}:${m.scoreB}</div>` : `<div class="match-score vs">VS</div>`;
            
            return `
                <div class="match-card">
                    <div class="match-header">
                        <span>${includeDate ? m.date + ' • ' : ''}${m.time} • ${m.field} ${m.stage.length <= 1 ? '(Группа '+m.stage+')' : '('+m.stage+')'}</span>
                        ${statusHTML}
                    </div>
                    <div class="match-teams">
                        <div class="team-name ${m.scoreA > m.scoreB ? 'winner' : ''}">${tA.name}</div>
                        ${scoreHTML}
                        <div class="team-name ${m.scoreB > m.scoreA ? 'winner' : ''}">${tB.name}</div>
                    </div>
                </div>
            `;
        }

        /* ==========================================================================
           ГЕНЕРАЦИЯ И РЕНДЕР СЕКЦИЙ
           ========================================================================== */
        
        // 1. ГЛАВНАЯ СТРАНИЦА
        function renderHome() {
            document.title = appData.settings.title;
            document.getElementById('hero-title').innerText = appData.settings.title;
            
            const stats = calculateTeamStats();
            let totalMatches = appData.matches.filter(m => m.status === 'finished').length;
            let totalGoals = Object.values(stats).reduce((sum, t) => sum + t.GF, 0);
            
            let finalDateObj = new Date(appData.settings.finalDate);
            let daysToFinal = Math.ceil((finalDateObj - new Date()) / (1000 * 60 * 60 * 24));
            
            document.getElementById('stat-teams').innerText = appData.teams.length;
            document.getElementById('stat-matches').innerText = totalMatches;
            document.getElementById('stat-goals').innerText = totalGoals;
            document.getElementById('stat-days').innerText = daysToFinal > 0 ? daysToFinal : '0';

            // Ближайшие и прошедшие
            const upcoming = appData.matches.filter(m => m.status !== 'finished').slice(0, 3);
            const finished = appData.matches.filter(m => m.status === 'finished').reverse().slice(0, 3);

            document.getElementById('home-upcoming').innerHTML = upcoming.length ? upcoming.map(m => generateMatchHTML(m)).join('') : '<p>Нет предстоящих матчей</p>';
            document.getElementById('home-results').innerHTML = finished.length ? finished.map(m => generateMatchHTML(m)).join('') : '<p>Нет завершенных матчей</p>';

            // Лидеры
            let topScorer = [...appData.players].sort((a,b) => b.goals - a.goals || a.matches - b.matches)[0];
            let topAssist = [...appData.players].sort((a,b) => b.assists - a.assists || a.matches - b.matches)[0];
            let topTeam = Object.values(stats).sort((a,b) => b.Pts - a.Pts || b.GD - a.GD)[0];

            if(topScorer) document.getElementById('home-top-scorer').innerHTML = `<h4>Лучший бомбардир</h4><div class="name">${topScorer.name}</div><div class="stat">${topScorer.goals} голов</div>`;
            if(topAssist) document.getElementById('home-top-assist').innerHTML = `<h4>Лучший ассистент</h4><div class="name">${topAssist.name}</div><div class="stat">${topAssist.assists} передач</div>`;
            if(topTeam) document.getElementById('home-top-team').innerHTML = `<h4>Лидер по очкам</h4><div class="name">${topTeam.name}</div><div class="stat">${topTeam.Pts} очков</div>`;

            // Новости
            document.getElementById('home-news').innerHTML = appData.news.map(n => `
                <div class="news-card">
                    <div class="news-date">${n.date}</div>
                    <div class="news-title">${n.title}</div>
                    <div class="news-excerpt">${n.excerpt}</div>
                    <button class="btn-link" onclick="toggleNews(${n.id}, this)">Читать далее</button>
                    <div class="news-full" id="news-full-${n.id}">${n.text}</div>
                </div>
            `).join('');
        }

        function toggleNews(id, btn) {
            const el = document.getElementById('news-full-'+id);
            el.classList.toggle('show');
            btn.innerText = el.classList.contains('show') ? 'Скрыть' : 'Читать далее';
        }

        // 2. ГРУППЫ
        function renderGroups() {
            const stats = calculateTeamStats();
            const groups = ['A', 'B', 'C', 'D'];
            let html = '';

            groups.forEach((g, idx) => {
            let groupTeams = Object.values(stats).filter(t => t.group === g).sort((a,b) => {
                // 1. По общему количеству очков
                if (b.Pts !== a.Pts) return b.Pts - a.Pts;
                
                // 2. По результатам личных встреч
                let h2hPtsA = 0, h2hPtsB = 0;
                let h2hGDA = 0, h2hGDB = 0;
                
                appData.matches.forEach(m => {
                    if (m.status !== 'finished') return;
                    if (m.teamA === a.id && m.teamB === b.id) {
                        if (m.scoreA > m.scoreB) h2hPtsA += 3;
                        else if (m.scoreA < m.scoreB) h2hPtsB += 3;
                        else { h2hPtsA += 1; h2hPtsB += 1; }
                        h2hGDA += (m.scoreA - m.scoreB);
                        h2hGDB += (m.scoreB - m.scoreA);
                    } else if (m.teamA === b.id && m.teamB === a.id) {
                        if (m.scoreB > m.scoreA) h2hPtsA += 3;
                        else if (m.scoreB < m.scoreA) h2hPtsB += 3;
                        else { h2hPtsA += 1; h2hPtsB += 1; }
                        h2hGDA += (m.scoreB - m.scoreA);
                        h2hGDB += (m.scoreA - m.scoreB);
                    }
                });
                
                if (h2hPtsB !== h2hPtsA) return h2hPtsB - h2hPtsA;
                if (h2hGDB !== h2hGDA) return h2hGDB - h2hGDA;
                
                // 3. По общей разнице мячей и количеству забитых
                if (b.GD !== a.GD) return b.GD - a.GD;
                return b.GF - a.GF;
            });
                let groupMatches = appData.matches.filter(m => m.stage === g);

                html += `
                <div class="group-section ${idx === 0 ? '' : 'hidden'}" id="group-${g}">
                    <div class="table-responsive">
                        <table class="group-table">
                            <thead>
                                <tr>
                                    <th>Команда</th>
                                    <th>И</th><th>В</th><th>Н</th><th>П</th>
                                    <th>Мячи</th><th>±</th><th>О</th>
                                </tr>
                            </thead>
                            <tbody>
                                ${groupTeams.map((t, i) => `
                                    <tr class="${i < 2 ? 'qualify' : 'out'}">
                                        <td style="display:flex; align-items:center; gap:10px; font-weight:700;">
                                            <div style="width:12px; height:12px; border-radius:50%; background:${t.color}"></div>
                                            ${t.name}
                                        </td>
                                        <td>${t.P}</td><td>${t.W}</td><td>${t.D}</td><td>${t.L}</td>
                                        <td>${t.GF}-${t.GA}</td><td>${t.GD > 0 ? '+'+t.GD : t.GD}</td>
                                        <td class="text-primary" style="font-weight:800;">${t.Pts}</td>
                                    </tr>
                                `).join('')}
                            </tbody>
                        </table>
                    </div>
                    <h3 style="margin:20px 0;">Матчи группы ${g}</h3>
                    <div class="match-list">
                        ${groupMatches.map(m => generateMatchHTML(m, true)).join('')}
                    </div>
                </div>`;
            });

            document.getElementById('group-content').innerHTML = html;

            // Логика табов
            document.querySelectorAll('#group-tabs .tab-btn').forEach(btn => {
                btn.onclick = () => {
                    document.querySelectorAll('#group-tabs .tab-btn').forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    document.querySelectorAll('.group-section').forEach(s => s.classList.add('hidden'));
                    document.getElementById(btn.dataset.target).classList.remove('hidden');
                }
            });
        }

        // 3. ПЛЕЙ-ОФФ
        function renderPlayoff() {
            // Для упрощения строим жесткую структуру
            const qf = appData.matches.filter(m => m.stage === '1/4');
            const sf = appData.matches.filter(m => m.stage === '1/2');
            const th = appData.matches.find(m => m.stage === '3rd') || { stage: "3rd", teamA: null, teamB: null };
            const fi = appData.matches.find(m => m.stage === 'Final') || { stage: "Final", teamA: null, teamB: null };

            function drawMatch(m) {
                if(!m) return '';
                const tA = getTeam(m.teamA);
                const tB = getTeam(m.teamB);
                return `
                    <div class="bracket-match">
                        <div class="bracket-team ${m.scoreA > m.scoreB ? 'winner' : ''}">
                            <span>${tA.name}</span>
                            <span class="bracket-score">${m.scoreA !== null ? m.scoreA : '-'}</span>
                        </div>
                        <div class="bracket-team ${m.scoreB > m.scoreA ? 'winner' : ''}">
                            <span>${tB.name}</span>
                            <span class="bracket-score">${m.scoreB !== null ? m.scoreB : '-'}</span>
                        </div>
                    </div>
                `;
            }

            document.getElementById('bracket-content').innerHTML = `
                <div class="bracket">
                    <div class="bracket-round">
                        <div class="bracket-title">1/4 Финала</div>
                        ${qf.map(m => drawMatch(m)).join('')}
                    </div>
                    <div class="bracket-round">
                        <div class="bracket-title">1/2 Финала</div>
                        ${sf.map(m => drawMatch(m)).join('')}
                    </div>
                    <div class="bracket-round">
                        <div class="bracket-title">Финал</div>
                        ${drawMatch(fi)}
                        <div class="third-place">
                            <div class="bracket-title">Матч за 3-е место</div>
                            ${drawMatch(th)}
                        </div>
                    </div>
                </div>
            `;
        }

        // 4 & 5. СТАТИСТИКА
        let currentStatMode = 'scorers';
        
        function renderStats(mode) {
            currentStatMode = mode;
            let sorted = [...appData.players];
            
            if(mode === 'scorers') {
                sorted.sort((a,b) => b.goals - a.goals || a.matches - b.matches);
                document.getElementById('stats-thead').innerHTML = `<tr><th>Место</th><th>Игрок</th><th>Команда</th><th>Голы</th><th>Матчи</th><th>Голов/Матч</th></tr>`;
            } else {
                sorted.sort((a,b) => b.assists - a.assists || a.matches - b.matches);
                document.getElementById('stats-thead').innerHTML = `<tr><th>Место</th><th>Игрок</th><th>Команда</th><th>Передачи</th><th>Матчи</th><th>Пер/Матч</th></tr>`;
            }

            const searchStr = document.getElementById('stats-search').value.toLowerCase();
            
            let html = '';
            let rank = 1;
            sorted.forEach((p) => {
                const team = getTeam(p.teamId);
                const val = mode === 'scorers' ? p.goals : p.assists;
                if(val === 0 && searchStr === '') return; // Скрываем нули если нет поиска
                
                if(p.name.toLowerCase().includes(searchStr) || team.name.toLowerCase().includes(searchStr)) {
                    let avg = p.matches > 0 ? (val / p.matches).toFixed(2) : "0.00";
                    html += `
                        <tr class="rank-${rank}">
                            <td>${rank}</td>
                            <td style="font-weight:700;">${p.name}</td>
                            <td>${team.name}</td>
                            <td class="text-primary" style="font-weight:800;">${val}</td>
                            <td>${p.matches}</td>
                            <td style="color:var(--color-text-muted);">${avg}</td>
                        </tr>
                    `;
                    rank++;
                }
            });
            document.getElementById('stats-tbody').innerHTML = html;
        }

        document.getElementById('btn-tab-scorers').onclick = (e) => {
            document.getElementById('btn-tab-assists').classList.remove('active');
            e.target.classList.add('active');
            renderStats('scorers');
        };
        document.getElementById('btn-tab-assists').onclick = (e) => {
            document.getElementById('btn-tab-scorers').classList.remove('active');
            e.target.classList.add('active');
            renderStats('assists');
        };
        document.getElementById('stats-search').addEventListener('input', () => renderStats(currentStatMode));

        // 6. РАСПИСАНИЕ
        function renderSchedule(filter = 'all') {
            let matches = [...appData.matches].sort((a,b) => new Date(a.date) - new Date(b.date));
            
            if(filter === 'group') matches = matches.filter(m => m.stage.length === 1);
            if(filter === 'playoff') matches = matches.filter(m => m.stage.length > 1);
            if(filter === 'upcoming') matches = matches.filter(m => m.status !== 'finished');
            if(filter === 'finished') matches = matches.filter(m => m.status === 'finished');

            // Группировка по дате
            const grouped = {};
            matches.forEach(m => {
                if(!grouped[m.date]) grouped[m.date] = [];
                grouped[m.date].push(m);
            });

            let html = '';
            for(const date in grouped) {
                html += `<h3 style="margin: 30px 0 15px; border-bottom: 1px solid var(--color-border); padding-bottom:10px;">${date}</h3>`;
                html += `<div class="match-list">${grouped[date].map(m => generateMatchHTML(m, false)).join('')}</div>`;
            }

            document.getElementById('schedule-content').innerHTML = html || '<p>Матчей не найдено</p>';
        }

        document.querySelectorAll('#schedule-filters .tab-btn').forEach(btn => {
            btn.onclick = () => {
                document.querySelectorAll('#schedule-filters .tab-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                renderSchedule(btn.dataset.filter);
            }
        });

