                        <option value="upcoming" ${m.status==='upcoming'?'selected':''}>Предстоит</option>
                        <option value="live" ${m.status==='live'?'selected':''}>LIVE</option>
                        <option value="finished" ${m.status==='finished'?'selected':''}>Завершён</option>
                    </select>
                    <button class="btn-sm" onclick="adminSaveMatch(${i})">Сохранить</button>
                </div>
                `;
            }).join('');
            document.getElementById('admin-matches-list').innerHTML = matchesHtml;

            // Игроки
            let playersHtml = appData.players.map((p, i) => `
                <div class="admin-row" style="grid-template-columns: 2fr 1fr 1fr 1fr auto;">
                    <div>${p.name} <span style="color:#666; font-size:0.8rem;">(${getTeam(p.teamId).name})</span></div>
                    <div><label>Голы</label><input type="number" id="pg-${i}" value="${p.goals}"></div>
                    <div><label>Пасы</label><input type="number" id="pa-${i}" value="${p.assists}"></div>
                    <div><label>Матчи</label><input type="number" id="pm-${i}" value="${p.matches}"></div>
                    <button class="btn-sm" onclick="adminSavePlayer(${i})">Сохранить</button>
                </div>
            `).join('');
            document.getElementById('admin-players-list').innerHTML = playersHtml;

            // Новости
            let newsHtml = appData.news.map((n, i) => `
                <div style="background:var(--color-card); padding:10px; margin-bottom:10px; border:1px solid var(--color-border); border-radius:8px; display:flex; justify-content:space-between; align-items:center;">
                    <div><strong>${n.title}</strong> <span style="color:#666; font-size:0.8rem;">${n.date}</span></div>
                    <button class="btn-sm btn-danger" onclick="adminDeleteNews(${i})">Удалить</button>
                </div>
            `).join('');
            document.getElementById('admin-news-list').innerHTML = newsHtml;

            // Настройки
            document.getElementById('set-title').value = appData.settings.title;
            document.getElementById('set-date').value = appData.settings.finalDate;
        }

        function adminSaveMatch(index) {
            let scA = document.getElementById(`scA-${index}`).value;
            let scB = document.getElementById(`scB-${index}`).value;
            let st = document.getElementById(`st-${index}`).value;
            
            appData.matches[index].scoreA = scA === '' ? null : parseInt(scA);
            appData.matches[index].scoreB = scB === '' ? null : parseInt(scB);
            appData.matches[index].status = st;
            
            if(scA !== '' && scB !== '' && st !== 'finished') {
            if(scA !== '' && scB !== '' && st === 'upcoming') {
                appData.matches[index].status = 'finished'; // Авто-перевод в завершен
                document.getElementById(`st-${index}`).value = 'finished';
            }

            saveData();
            alert('Матч сохранен!');
        }

        function adminSavePlayer(index) {
            appData.players[index].goals = parseInt(document.getElementById(`pg-${index}`).value) || 0;
            appData.players[index].assists = parseInt(document.getElementById(`pa-${index}`).value) || 0;
            appData.players[index].matches = parseInt(document.getElementById(`pm-${index}`).value) || 0;
            saveData();
            alert('Статистика игрока обновлена!');
        }

        function adminAddNews() {
            let t = document.getElementById('new-news-title').value;
            let txt = document.getElementById('new-news-text').value;
            if(!t || !txt) return alert("Заполните все поля");
            
            let today = new Date().toISOString().split('T')[0];
            appData.news.unshift({
                id: Date.now(),
                title: t,
                date: today,
                excerpt: txt.substring(0, 100) + '...',
                text: txt
            });
            saveData();
            renderAdmin();
            document.getElementById('new-news-title').value = '';
            document.getElementById('new-news-text').value = '';
        }

        function adminDeleteNews(index) {
            if(confirm('Точно удалить новость?')) {
                appData.news.splice(index, 1);
                saveData();
                renderAdmin();
            }
        }

        function adminSaveSettings() {
            appData.settings.title = document.getElementById('set-title').value;
            appData.settings.finalDate = document.getElementById('set-date').value;
            saveData();
            alert('Настройки сохранены');
        }

        // Экспорт и Импорт
        function exportData() {
            const jsonStr = JSON.stringify(appData, null, 2);
            const blob = new Blob([jsonStr], { type: "application/json" });
            const url = URL.createObjectURL(blob);
            const downloadAnchorNode = document.createElement('a');
            downloadAnchorNode.setAttribute("href", url);
            downloadAnchorNode.setAttribute("download", "urban_cup_data.json");
            document.body.appendChild(downloadAnchorNode);
            downloadAnchorNode.click();
            downloadAnchorNode.remove();
            URL.revokeObjectURL(url);
        }

        function importData(event) {
            const file = event.target.files[0];
            if(!file) return;
            const reader = new FileReader();
            reader.onload = (e) => {
                try {
                    appData = JSON.parse(e.target.result);
                    saveData();
                    alert("Данные успешно импортированы!");
                    renderAdmin();
                } catch(err) {
                    alert("Ошибка чтения файла JSON");
                }
                event.target.value = ''; // Сброс инпута, чтобы можно было загрузить этот же файл повторно
            };
            reader.readAsText(file);
        }

        // Табы админки
        document.querySelectorAll('#admin-tabs .tab-btn').forEach(btn => {
            btn.onclick = () => {
                document.querySelectorAll('#admin-tabs .tab-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                document.querySelectorAll('.admin-tab-content').forEach(c => c.classList.add('hidden'));
                document.getElementById(btn.dataset.target).classList.remove('hidden');
            }
        });

        /* ==========================================================================
           ИНИЦИАЛИЗАЦИЯ
           ========================================================================== */
        function renderAll() {
            renderHome();
            renderGroups();
            renderPlayoff();
            if(currentStatMode) renderStats(currentStatMode);
            renderSchedule();
            renderTeams();
        }

        window.onload = () => {
            renderAll();
            // Если в URL есть hash #admin, пробуем показать модалку логина, но не открываем саму админку без пароля
            if(window.location.hash === '#admin') {
                document.getElementById('login-modal').classList.add('open');
                // Сбрасываем hash чтобы не сломать логику SPA
                window.history.replaceState(null, null, ' ');
                navigate('#home');
            } else {
                navigate(window.location.hash || '#home');
            }
        };
    </script>
</body>
</html>
