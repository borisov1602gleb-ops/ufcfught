<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UFC Fight: Ренальд vs Фаридун</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: 'Arial', sans-serif;
            background-color: #000;
            color: #fff;
            text-transform: uppercase;
        }
        .header {
            text-align: center;
            padding: 20px;
            background-color: #d90000;
            font-size: 24px;
            font-weight: bold;
            letter-spacing: 2px;
        }
        .fight-container {
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 50px 20px;
            gap: 50px;
            background: radial-gradient(circle, #333 0%, #000 80%);
            min-height: 80vh;
        }
        .fighter {
            text-align: center;
            background: rgba(255, 255, 255, 0.1);
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0 0 20px rgba(217, 0, 0, 0.5);
            width: 250px;
            transition: transform 0.3s ease;
        }
        .fighter:hover {
            transform: scale(1.05);
        }
        .fighter-img {
            width: 150px;
            height: 150px;
            background-color: #555;
            border-radius: 50%;
            margin: 0 auto 20px auto;
            border: 4px solid #d90000;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            color: #ccc;
            overflow: hidden;
        }
        .fighter-name {
            font-size: 28px;
            font-weight: bold;
            margin-bottom: 10px;
        }
        .odds {
            font-size: 36px;
            color: #FFD700;
            font-weight: bold;
            margin: 15px 0;
        }
        .btn {
            background-color: #d90000;
            color: #fff;
            border: none;
            padding: 10px 20px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            border-radius: 5px;
            text-transform: uppercase;
            transition: background 0.3s;
            width: 100%;
        }
        .btn:hover {
            background-color: #ff1a1a;
        }
        .vs {
            font-size: 60px;
            font-weight: bold;
            font-style: italic;
            color: #d90000;
            text-shadow: 2px 2px 10px rgba(0,0,0,0.8);
        }
        .stats {
            font-size: 14px;
            color: #aaa;
            margin-bottom: 15px;
            line-height: 1.6;
        }
        @media (max-width: 768px) {
            .fight-container {
                flex-direction: column;
            }
        }
    </style>
</head>
<body>

<div class="header">
    Главный бой вечера
</div>

<div class="fight-container">
    <!-- Ренальд -->
    <div class="fighter">
        <div class="fighter-img">Фото Ренальда</div>
        <div class="fighter-name">Ренальд</div>
        <div class="stats">
            Рост: 180 см<br>
            Вес: 77 кг<br>
            Стиль: Борьба
        </div>
        <div class="odds">1.85</div>
        <button class="btn" onclick="alert('Ставка на Ренальда принята!')">Поставить</button>
    </div>

    <!-- VS -->
    <div class="vs">VS</div>

    <!-- Фаридун -->
    <div class="fighter">
        <div class="fighter-img">Фото Фаридуна</div>
        <div class="fighter-name">Фаридун</div>
        <div class="stats">
            Рост: 182 см<br>
            Вес: 76.5 кг<br>
            Стиль: Ударник
        </div>
        <div class="odds">2.10</div>
        <button class="btn" onclick="alert('Ставка на Фаридуна принята!')">Поставить</button>
    </div>
</div>

</body>
</html>
