        function renderAdmin() {
            // Матчи
            let matchesHtml = appData.matches.map((m, i) => {
                return `
                <div class="admin-row">
                    <div>${m.date} | ${getTeam(m.teamA).name} - ${getTeam(m.teamB).name}</div>
                    <input type="number" id="scA-${i}" value="${m.scoreA !== null ? m.scoreA : ''}" placeholder="-">
